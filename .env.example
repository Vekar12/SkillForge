# Google OAuth (optional — demo mode works without it)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# GitHub fine-grained PAT for storing skill requests in skill-requests.csv
# Permissions needed: Contents → Read and write (this repo only)
# Create at: https://github.com/settings/personal-access-tokens/new
VITE_GITHUB_TOKEN=github_pat_xxxx
VITE_GITHUB_REPO=Vekar12/SkillForge
